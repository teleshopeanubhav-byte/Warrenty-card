rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "Anubhavmaheshwariap8@gmail.com" || 
         request.auth.token.email == "admin@buntyelectronics.com");
    }

    function isValidWarranty(data) {
      return data.customerName is string && data.customerName.size() > 0 &&
             data.phoneNumber is string && data.phoneNumber.size() >= 10 &&
             data.product is string && data.product.size() > 0 &&
             data.serialNumber is string && data.serialNumber.size() > 0 &&
             data.price is number &&
             data.purchaseDate is string &&
             data.expiryDate is string &&
             data.createdAt is number;
    }

    match /warranties/{warrantyId} {
      // Anyone can create a warranty registration
      allow create: if isValidWarranty(request.resource.data);
      
      // Only admin can read, update, or delete
      allow read, update, delete: if isAdmin();
    }
  }
}
